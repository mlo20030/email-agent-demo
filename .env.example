# Model provider — Anthropic is the default in models.py
ANTHROPIC_API_KEY="<anthropic-api-key>"

# Or use OpenAI instead (swap the model in models.py)
# OPENAI_API_KEY="<openai-api-key>"

# LangSmith tracing (recommended; required when deploying to LangSmith)
LANGSMITH_API_KEY="<langsmith-api-key>"
LANGSMITH_TRACING="true"
LANGSMITH_PROJECT="email-agent-demo"
